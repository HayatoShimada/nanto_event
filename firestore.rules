rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
      allow delete: if false;
    }

    // teams
    match /teams/{teamId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.members;
      allow update, delete: if isAuthenticated() && request.auth.uid in resource.data.members;
    }

    // events
    match /events/{eventId} {
      function isOrganizer(data) {
        let orgType = data.get('organizerType', 'user');
        let orgUid = data.get('organizerUid', '');
        let teamRef = /databases/$(database)/documents/teams/$(orgUid);
        
        return (orgType == 'user' && orgUid == request.auth.uid) ||
               (orgType == 'team' && exists(teamRef) && request.auth.uid in get(teamRef).data.members);
      }

      allow read: if true;
      allow create: if isAuthenticated() && isOrganizer(request.resource.data);
      allow update: if isAuthenticated() && isOrganizer(resource.data);
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pageViews', 'participationClicks']);
      allow delete: if isAuthenticated() && isOrganizer(resource.data);
    }

    // event_collaborators
    match /event_collaborators/{docId} {
      allow read: if isAuthenticated();
      // Allow if the user is the organizer of the event
      allow create, update, delete: if isAuthenticated() &&
        get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizerUid == request.auth.uid;
    }

    // event_participations
    match /event_participations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'attending';
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow read: if false;
      allow create: if false;
    }

    // email_templates
    match /email_templates/{templateId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
